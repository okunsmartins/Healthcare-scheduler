# =============================================================================
# Healthcare Scheduler Portal — environment variables
# =============================================================================
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Variables are validated at startup by src/lib/env — the app will refuse to
# start with an invalid configuration (fail fast, not fail silent).
#
# NEXT_PUBLIC_* variables are exposed to the browser bundle. Everything else is
# SERVER-ONLY and must never be imported into client components.
# =============================================================================

# --- Public (safe to expose to the browser) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-local-anon-key"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Server-only (NEVER expose to the browser) ------------------------------
# The service-role key bypasses RLS. Reference ONLY from server-only modules.
SUPABASE_SERVICE_ROLE_KEY="replace-with-local-service-role-key"

# Email provider: "console" (dev default) | "resend"
EMAIL_PROVIDER="console"
# Required only when EMAIL_PROVIDER=resend
RESEND_API_KEY=""

# Optional error reporting (Sentry-compatible abstraction). Leave blank to disable.
SENTRY_DSN=""

# Shared secret used to authorise scheduled/cron job invocations.
CRON_SECRET="replace-with-a-long-random-string"
